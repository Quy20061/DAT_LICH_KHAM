# ──────────────────────────────────────────────────────────────
#  CẤU HÌNH BIẾN MÔI TRƯỜNG  (copy file này thành .env để chạy local)
#  TUYỆT ĐỐI KHÔNG commit file .env thật lên GitHub.
# ──────────────────────────────────────────────────────────────

# Cổng chạy server (local). Trên Render để trống, Render tự cấp PORT.
PORT=3000

# Môi trường: đặt "production" khi deploy (bật cookie secure qua HTTPS)
NODE_ENV=development

# Khóa bí mật ký session — đặt một chuỗi ngẫu nhiên dài, khó đoán
SESSION_SECRET=hay_thay_bang_chuoi_ngau_nhien_dai

# Email quản trị (phân tách bằng dấu phẩy). Ai đăng nhập bằng email này sẽ thành admin.
ADMIN_EMAILS=admin@phongkham.vn

# Khóa bảo vệ endpoint cron nhắc lịch (đặt chuỗi ngẫu nhiên).
# Dịch vụ ping bên ngoài phải gửi đúng khóa này mới chạy được.
CRON_SECRET=hay_thay_bang_chuoi_ngau_nhien_khac

# Tắt cron nội bộ (mặc định bật). Trên Render free nên để bật, kết hợp ping ngoài.
# ENABLE_INTERNAL_CRON=false

# ── CẤU HÌNH SMTP GỬI EMAIL THẬT ──────────────────────────────
# CÁCH 1 — Gmail App Password (dễ nhất cho đồ án):
#   1. Bật xác minh 2 bước cho tài khoản Gmail.
#   2. Vào https://myaccount.google.com/apppasswords tạo "App password".
#   3. Dán mật khẩu ứng dụng (16 ký tự) vào SMTP_PASS bên dưới.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tai_khoan_cua_ban@gmail.com
SMTP_PASS=mat_khau_ung_dung_16_ky_tu
MAIL_FROM=Phòng khám Online <tai_khoan_cua_ban@gmail.com>

# CÁCH 2 — SendGrid (thay phần trên bằng):
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=apikey
#   SMTP_PASS=SG.xxxxxxxx_api_key_cua_ban
#   MAIL_FROM=email_da_xac_thuc@tenmien.com

# Nếu KHÔNG cấu hình SMTP, app vẫn chạy ở "chế độ console":
# email chỉ in ra log (không gửi thật) — tiện để demo nhanh.
